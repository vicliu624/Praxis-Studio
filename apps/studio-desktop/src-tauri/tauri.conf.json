{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Praxis Studio",
  "version": "0.1.0",
  "identifier": "studio.praxis.app",
  "build": { "beforeDevCommand": "npm run dev", "beforeBuildCommand": "npm run build", "devUrl": "http://localhost:1420", "frontendDist": "../dist" },
  "app": { "windows": [{ "title": "Praxis Studio", "width": 1400, "height": 900, "minWidth": 1100, "minHeight": 760 }] },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["../../runtime-cli/dist/**/*"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDNTNGMEIzNThEODU3QjUKUldTMVY5aFlzL0JUdkRoVWtkWVFIRWhuQ2ZPUXFVTHlhcUNyUTg1MHVLRStkT3dWRVRRNWVZQXAK",
      "endpoints": ["https://github.com/vicliu624/Praxis-Studio/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
