{
  "name": "@praxis/agent-loop",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "description": "Continuous agent run loop with step tracking, permission gating, and run persistence.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@praxis/core": "0.1.0-alpha.0",
    "@praxis/tool-registry": "0.1.0-alpha.0",
    "@praxis/model-router": "0.1.0-alpha.0",
    "@praxis/provider-deepseek": "0.1.0-alpha.0",
    "@praxis/prompt-registry": "0.1.0-alpha.0",
    "@praxis/context-builder": "0.1.0-alpha.0",
    "@praxis/development-graph": "0.1.0-alpha.0",
    "@praxis/local-knowledge": "0.1.0-alpha.0",
    "@praxis/trace-recorder": "0.1.0-alpha.0",
    "@praxis/plan-model": "0.1.0-alpha.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    }
  }
}
